# ── LLM Backend ──────────────────────────────────────────────
# Options: openrouter | lmstudio | ollama
LLM_BACKEND=lmstudio

# ── OpenRouter (cloud) ──────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here
OPENROUTER_MODEL=qwen/qwen3-1.7b
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT=120
OPENROUTER_TEMPERATURE=0.0
OPENROUTER_MAX_TOKENS=8192

# ── LM Studio (local) ───────────────────────────────────────
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=gemma-3-4b-it
LM_STUDIO_TIMEOUT=120
LM_STUDIO_TEMPERATURE=0.0
LM_STUDIO_MAX_TOKENS=8192

# ── Ollama (local) ──────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen3:1.7b
OLLAMA_TIMEOUT=120
OLLAMA_TEMPERATURE=0.0
OLLAMA_MAX_TOKENS=8192

# ── Reasoning (for Qwen 3, DeepSeek-R1, etc.) ───────────────
LLM_REASONING_ENABLED=false

# ── Input Truncation ────────────────────────────────────────
LLM_MAX_INPUT_CHARS=200000

# ── PDF Parsing ─────────────────────────────────────────────
PDF_PARSE_MODE=auto
OCR_LANGUAGE=eng
OCR_MIN_CHARS=300

# ── PDF Layout ──────────────────────────────────────────────
PDF_PAGE_LAYOUT=auto

# ── QR Code Scanning ────────────────────────────────────────
QR_SCAN_ENABLED=true
QR_SAVE_ARTIFACTS=false

# ── Photo Extraction ────────────────────────────────────────
PHOTO_ENABLED=true
PHOTO_DIR=data/photos

# ── Rate Limiting & Retry ───────────────────────────────────
LLM_MAX_RETRIES=3
LLM_RETRY_BACKOFF=2.0
LLM_MAX_CONCURRENT=1
