# ── LLM Backend ──────────────────────────────────────────────
# Options: lmstudio | openrouter
LLM_BACKEND=lmstudio

# ── LM Studio (used when LLM_BACKEND=lmstudio) ───────────────
LM_STUDIO_BASE_URL=http://ai.amirulaliff.com/v1
LM_STUDIO_MODEL=gemma-3-4b-it
LM_STUDIO_TIMEOUT=120
LM_STUDIO_TEMPERATURE=0.0
LM_STUDIO_MAX_TOKENS=4096

# ── OpenRouter (used when LLM_BACKEND=openrouter) ────────────
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=liquid/lfm-2-24b-a2b
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT=120
OPENROUTER_TEMPERATURE=0.0
OPENROUTER_MAX_TOKENS=4096

# ── Remote Marker (offload extraction to server) ─────────────
# REMOTE_MARKER_URL=http://ai.amirulaliff.com:8001
